generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  owner
  admin
  member
  client
}

enum PlanStatus {
  trial
  active
  grace
  suspended
}

enum SiteBuildStatus {
  building
  validated
  failed
}

enum SiteDeploymentStatus {
  published
  rolled_back
  superseded
}

enum DomainState {
  domain_entered
  verification_required
  dns_records_pending
  verified
  misconfigured
  failed
}

enum ActionStatus {
  proposed
  pending
  approved
  rejected
  executed
  failed
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum TaskStatus {
  open
  queued
  done
}

enum FalconJobStatus {
  pending
  running
  succeeded
  failed
}

enum ClientAccessStatus {
  active
  past_due
  suspended
  revoked
}

enum PaymentStatus {
  trialing
  paid
  due
  failed
  cancelled
}

enum GatewayProvider {
  local
  pangolin
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?
  name         String?
  /* Platform super-admin (Jordan). Distinct from any per-org role — org
     owners/admins are Membership.role, never this flag. */
  isSuperAdmin Boolean      @default(false)
  activeOrgId  String?
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  chatThreads  ChatThread[]
  decisions    Approval[]   @relation("ApprovalDecider")
  authSessions AuthSession[]
  sentInvitations Invitation[] @relation("InvitationInviter")
}

/* Server-side login session for the database auth provider. Revocation is
   real: a revoked or expired row can never resolve to an AccessSession. */
model AuthSession {
  id          String    @id @default(uuid())
  userId      String
  activeOrgId String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/* Org invitations. Only the SHA-256 hash of the invite token is stored —
   the raw token is shown once at creation time. */
model Invitation {
  id               String         @id @default(uuid())
  orgId            String
  email            String
  role             MembershipRole @default(member)
  tokenHash        String         @unique
  invitedByUserId  String
  createdAt        DateTime       @default(now())
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  revokedAt        DateTime?
  org              Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy        User           @relation("InvitationInviter", fields: [invitedByUserId], references: [id])

  @@index([orgId, email])
}

/* Provider-neutral plan catalog. Feature flags and limits are structured
   JSON resolved by the entitlement engine; no billing provider implied. */
model Plan {
  key         String    @id
  name        String
  description String
  isInternal  Boolean   @default(false)
  features    Json
  limits      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orgPlans    OrgPlan[]
}

model OrgPlan {
  id               String     @id @default(uuid())
  orgId            String     @unique
  planKey          String
  status           PlanStatus @default(trial)
  trialEndsAt      DateTime?
  graceUntil       DateTime?
  /* Manual super-admin overrides: partial feature/limit patches. */
  overrides        Json?
  assignedByUserId String?
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  org              Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan             Plan       @relation(fields: [planKey], references: [key])

  @@index([planKey])
}

/* Usage ledger — one row per consumed unit batch (chat request, media
   credit, storage bytes…). Aggregated per reset period for limit checks. */
model UsageEvent {
  id        String   @id @default(uuid())
  orgId     String
  metric    String
  amount    Float
  at        DateTime @default(now())
  meta      Json?
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, metric, at])
}

/* Server-side website records for the publishing pipeline. The in-browser
   builder remains the editor; publishing registers the site here. */
model Site {
  id          String           @id @default(uuid())
  orgId       String
  title       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  org         Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  builds      SiteBuild[]
  deployments SiteDeployment[]
  domains     SiteDomain[]

  @@index([orgId])
}

model SiteBuild {
  id              String          @id @default(uuid())
  siteId          String
  orgId           String
  version         Int
  status          SiteBuildStatus @default(building)
  contentPath     String
  buildLog        String
  createdByUserId String?
  createdAt       DateTime        @default(now())
  site            Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  deployments     SiteDeployment[]

  @@unique([siteId, version])
  @@index([orgId])
}

model SiteDeployment {
  id                String               @id @default(uuid())
  siteId            String
  orgId             String
  buildId           String
  status            SiteDeploymentStatus @default(published)
  publishedAt       DateTime             @default(now())
  publishedByUserId String?
  approvedByUserId  String?
  runId             String?
  receipt           Json
  site              Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  build             SiteBuild            @relation(fields: [buildId], references: [id])

  @@index([siteId, status])
  @@index([orgId])
}

model SiteDomain {
  id                String      @id @default(uuid())
  siteId            String
  orgId             String
  domain            String
  state             DomainState @default(domain_entered)
  verificationToken String
  sslState          String      @default("unknown")
  checkedAt         DateTime?
  lastError         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  site              Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, domain])
  @@index([orgId])
}

model Org {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now())
  memberships Membership[]
  connections Connection[]
  chatThreads ChatThread[]
  actions     Action[]
  approvals   Approval[]
  tasks       Task[]
  notes       Note[]
  contacts    Contact[]
  auditEvents AuditEvent[]
  falconJobs  FalconJob[]
  clientAccess ClientAccess?
  moduleEntitlements ModuleEntitlement[]
  invitations Invitation[]
  orgPlan     OrgPlan?
  usageEvents UsageEvent[]
  sites       Site[]
}

model Membership {
  id        String         @id @default(uuid())
  userId    String
  orgId     String
  role      MembershipRole @default(member)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model Connection {
  id             String   @id @default(uuid())
  orgId          String
  type           String
  status         String
  encryptedToken Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  org            Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, type])
}

model ChatThread {
  id        String        @id @default(uuid())
  orgId     String
  userId    String
  title     String?
  createdAt DateTime      @default(now())
  org       Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([orgId])
}

model ChatMessage {
  id        String     @id @default(uuid())
  threadId  String
  role      String
  content   String
  actionId  String?
  createdAt DateTime   @default(now())
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  action    Action?    @relation(fields: [actionId], references: [id])

  @@index([threadId])
}

model Action {
  id          String        @id @default(uuid())
  orgId       String
  type        String
  payload     Json
  policy      Json
  status      ActionStatus  @default(proposed)
  proposedBy  String
  rationale   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  org         Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  approval    Approval?
  tasks       Task[]
  falconJobs  FalconJob[]
  messages    ChatMessage[]

  @@index([orgId, status])
  @@index([orgId, type])
}

model Approval {
  id              String         @id @default(uuid())
  orgId           String
  actionId         String         @unique
  status          ApprovalStatus @default(pending)
  decidedByUserId String?
  decidedAt       DateTime?
  reason          String?
  payload         Json?
  createdAt       DateTime       @default(now())
  org             Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  action          Action         @relation(fields: [actionId], references: [id], onDelete: Cascade)
  decidedBy       User?          @relation("ApprovalDecider", fields: [decidedByUserId], references: [id])

  @@index([orgId, status])
}

model Task {
  id             String     @id @default(uuid())
  orgId          String
  title          String
  status         TaskStatus @default(open)
  dueAt          DateTime?
  priority       String     @default("medium")
  project        String?
  sourceActionId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  org            Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sourceAction   Action?    @relation(fields: [sourceActionId], references: [id])

  @@index([orgId, status])
}

model Note {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  body      String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Contact {
  id           String   @id @default(uuid())
  orgId        String
  name         String
  email        String?
  phone        String?
  organization String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model ClientAccess {
  id              String             @id @default(uuid())
  orgId           String             @unique
  gatewayProvider GatewayProvider    @default(pangolin)
  privateRoute    String?
  accessStatus    ClientAccessStatus @default(active)
  paymentStatus   PaymentStatus      @default(paid)
  planName         String?
  ownerName        String?
  connectorCredentials Json?
  lastAudit        String?
  revokedAt       DateTime?
  revokedReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  org             Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([accessStatus])
  @@index([paymentStatus])
}

model ModuleEntitlement {
  id        String   @id @default(uuid())
  orgId     String
  moduleKey String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleKey])
  @@index([orgId, enabled])
}

model AuditEvent {
  id         String   @id @default(uuid())
  orgId      String
  actor      String
  eventType  String
  targetType String
  targetId   String
  payload    Json
  prevHash   String?
  hash       String
  createdAt  DateTime @default(now())
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, targetType, targetId])
}

model FalconJob {
  id          String          @id @default(uuid())
  orgId       String
  actionId    String?
  jobType     String
  typedInput  Json
  typedOutput Json?
  status      FalconJobStatus @default(pending)
  error       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  org         Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  action      Action?         @relation(fields: [actionId], references: [id])

  @@index([orgId, status])
  @@index([orgId, jobType])
}
