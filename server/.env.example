# PhantomForce server environment — EXAMPLE FILE, safe to commit.
# Copy to server/.env and fill in real values. server/.env is gitignored;
# never commit a real connection string, secret, or login key.

# ---------------------------------------------------------------------------
# Database (PostgreSQL — the repository's Prisma schema targets postgresql)
# Local development example; see docs/DATABASE_SETUP.md for setup steps.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://phantomforce:CHANGE-ME@127.0.0.1:5432/phantomforce_dev

# ---------------------------------------------------------------------------
# Auth provider — one of: demo | prisma-dev | database | owner-production |
# gateway-forwarded
#   demo              in-memory seed sessions (dev only, no DB needed)
#   prisma-dev        seeded Prisma sessions (dev only, session-id login)
#   database          REAL multi-user auth: Postgres users, password login,
#                     org memberships, invitations (dev + production)
#   owner-production  single owner key login (the current admin-PC setup)
#   gateway-forwarded Pangolin forward-auth single sign-on
# ---------------------------------------------------------------------------
PHANTOMFORCE_AUTH_PROVIDER=database

# Required for every provider in production; >= 32 chars, non-default.
PHANTOMFORCE_SESSION_SECRET=CHANGE-ME-to-a-long-random-string-32-chars-min

# Session TTL (ms). Default 8h.
# PHANTOMFORCE_SESSION_TTL_MS=28800000

# Invitation TTL (ms). Default 7 days.
# PHANTOMFORCE_INVITATION_TTL_MS=604800000

# database provider, development only: seed the dev identities on boot
# (dev-org-*/dev-user-* fixtures with .local emails). Set false to disable.
# Never runs when NODE_ENV=production.
# PHANTOMFORCE_SEED_DEV_IDENTITIES=true
# PHANTOMFORCE_DEV_SEED_PASSWORD=phantom-dev-password

# ---------------------------------------------------------------------------
# owner-production provider (existing admin-PC setup) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_OWNER_EMAIL=
# PHANTOMFORCE_OWNER_LOGIN_KEY=

# ---------------------------------------------------------------------------
# gateway-forwarded provider (Pangolin) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_GATEWAY_SHARED_SECRET=
# PHANTOMFORCE_GATEWAY_ADMIN_USERS=
# PHANTOMFORCE_GATEWAY_CLIENT_MAP=

# ---------------------------------------------------------------------------
# Billing — Stripe Checkout + Customer Portal
# ---------------------------------------------------------------------------
# Hosted Stripe Checkout keeps card, Apple Pay, PayPal, and Link credentials
# out of PhantomForce. Leave this disabled until every item in
# docs/STRIPE_BILLING_SETUP.md is complete. Never put live values in Git.
#
# PHANTOMFORCE_STRIPE_BILLING_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
#
# Create these recurring Stripe Prices in the Stripe Dashboard. The browser
# never receives Price IDs or amount authority; the server chooses only from
# this allowlist. Configure at least one interval for each plan you sell.
# STRIPE_PRICE_PRO_MONTHLY=price_replace_me
# STRIPE_PRICE_PRO_YEARLY=price_replace_me
# STRIPE_PRICE_DEVELOPER_MONTHLY=price_replace_me
# STRIPE_PRICE_DEVELOPER_YEARLY=price_replace_me
# STRIPE_PRICE_ELITE_MONTHLY=price_replace_me
# STRIPE_PRICE_ELITE_YEARLY=price_replace_me
# STRIPE_PRICE_DEVELOPER_ELITE_MONTHLY=price_replace_me
# STRIPE_PRICE_DEVELOPER_ELITE_YEARLY=price_replace_me
#
# Optional. If empty, Stripe uses the Dashboard-managed default Customer Portal
# configuration. Configure portal settings in the Stripe Dashboard either way.
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_replace_me
#
# Optional tax collection controls. Set only after the corresponding Stripe
# Tax / registration configuration is complete.
# PHANTOMFORCE_STRIPE_AUTOMATIC_TAX=false
# PHANTOMFORCE_STRIPE_TAX_ID_COLLECTION=false
#
# Optional: only an approved HTTPS public origin may be used for post-checkout
# returns. Defaults safely to https://admin.phantomforce.online.
# PHANTOMFORCE_STRIPE_RETURN_ORIGIN=https://admin.phantomforce.online
#
# Legacy provider-neutral manual webhook (not used by Stripe Checkout):
# PHANTOM_BILLING_WEBHOOK_SECRET=

# Local asset library (Media Lab "Local Assets" drawer). Point ROOT at the
# folder of downloaded/stock media on this machine; LABEL is the neutral name
# customers see (never the folder name). The index is cached on disk inside
# the root so cold starts serve instantly.
# Default when unset: G:\Motionarray download here (falls back to
# G:\Motionarray download if the "here" folder does not exist).
# PHANTOMFORCE_LOCAL_ASSET_ROOT=G:\Motionarray download here
# PHANTOMFORCE_LOCAL_ASSET_LABEL=Local library

# Social OAuth app credentials (Settings > Media & social > OAuth apps).
# Users connect their own accounts in the browser after these provider apps are
# configured once. Account tokens are stored server-side and redacted from API
# responses. Posting/upload scopes remain approval-gated by PhantomForce.
# SOCIAL_OAUTH_REDIRECT_URI=https://admin.phantomforce.online/phantom-ai/ops/social-oauth/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# PINTEREST_CLIENT_ID=
# PINTEREST_CLIENT_SECRET=
