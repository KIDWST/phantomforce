# PhantomForce server environment — EXAMPLE FILE, safe to commit.
# Copy to server/.env and fill in real values. server/.env is gitignored;
# never commit a real connection string, secret, or login key.

# ---------------------------------------------------------------------------
# Database (PostgreSQL — the repository's Prisma schema targets postgresql)
# Local development example; see docs/DATABASE_SETUP.md for setup steps.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://phantomforce:CHANGE-ME@127.0.0.1:5432/phantomforce_dev

# ---------------------------------------------------------------------------
# Auth provider — one of: demo | prisma-dev | database | owner-production |
# gateway-forwarded
#   demo              in-memory seed sessions (dev only, no DB needed)
#   prisma-dev        seeded Prisma sessions (dev only, session-id login)
#   database          REAL multi-user auth: Postgres users, password login,
#                     org memberships, invitations (dev + production)
#   owner-production  single owner key login (the current admin-PC setup)
#   gateway-forwarded Pangolin forward-auth single sign-on
# ---------------------------------------------------------------------------
PHANTOMFORCE_AUTH_PROVIDER=database

# Required for every provider in production; >= 32 chars, non-default.
PHANTOMFORCE_SESSION_SECRET=CHANGE-ME-to-a-long-random-string-32-chars-min

# Session TTL (ms). Default 8h.
# PHANTOMFORCE_SESSION_TTL_MS=28800000

# Invitation TTL (ms). Default 7 days.
# PHANTOMFORCE_INVITATION_TTL_MS=604800000

# database provider, development only: seed the dev identities on boot
# (dev-org-*/dev-user-* fixtures with .local emails). Set false to disable.
# Never runs when NODE_ENV=production.
# PHANTOMFORCE_SEED_DEV_IDENTITIES=true
# PHANTOMFORCE_DEV_SEED_PASSWORD=phantom-dev-password

# ---------------------------------------------------------------------------
# owner-production provider (existing admin-PC setup) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_OWNER_EMAIL=
# PHANTOMFORCE_OWNER_LOGIN_KEY=

# ---------------------------------------------------------------------------
# gateway-forwarded provider (Pangolin) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_GATEWAY_SHARED_SECRET=
# PHANTOMFORCE_GATEWAY_ADMIN_USERS=
# PHANTOMFORCE_GATEWAY_CLIENT_MAP=

# ---------------------------------------------------------------------------
# Billing webhook (provider-neutral; no provider integrated yet)
# ---------------------------------------------------------------------------
# PHANTOM_BILLING_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Social analytics — official OAuth apps (server/src/connectors/social-analytics-connector.ts)
#
# Being logged into a platform in your own browser does NOT give this app
# access to your analytics. Each platform requires its own registered
# developer/OAuth app (created by you in that platform's developer console),
# whose Client ID/Secret go here. Once the app-level credentials below exist,
# use Settings > Social in the admin UI to run the actual per-account OAuth
# consent flow (that's what stores the account-level access/refresh token in
# server/.phantom/social-connections.json — never put account tokens here).
#
# Redirect URI to register with each platform (unless overridden per-platform
# with <PLATFORM>_OAUTH_REDIRECT_URI, or globally with SOCIAL_OAUTH_REDIRECT_URI):
#   <ADMIN_PUBLIC_URL>/phantom-ai/ops/social-oauth/callback
# ---------------------------------------------------------------------------
# YouTube — Google Cloud Console > APIs & Services > Credentials (OAuth client ID)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: skip OAuth and use a server-side API key + public channel id/handle instead
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=
# YOUTUBE_CHANNEL_HANDLE=

# Instagram + Facebook — developers.facebook.com app (needs Instagram Graph API +
# Facebook Login for Business products; instagram_manage_insights/read_insights
# require Meta App Review before they work for non-admin/tester accounts)
# META_APP_ID=
# META_APP_SECRET=
# META_GRAPH_VERSION=v21.0

# TikTok — developers.tiktok.com app (Login Kit)
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# X (Twitter) — developer.x.com app (OAuth 2.0 with PKCE)
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# LinkedIn — developer.linkedin.com app (Marketing Developer Platform access
# required for organization follower statistics)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# LINKEDIN_ORGANIZATION_ID=

# Pinterest — developers.pinterest.com app
# PINTEREST_CLIENT_ID=
# PINTEREST_CLIENT_SECRET=

# Optional global override if all platforms should share one redirect URI:
# SOCIAL_OAUTH_REDIRECT_URI=
# Optional: where account-level OAuth tokens are stored (defaults to
# PHANTOMFORCE_DATA_DIR or ./.phantom relative to the server process cwd)
# PHANTOMFORCE_SOCIAL_DATA_DIR=
