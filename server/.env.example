# PhantomForce server environment — EXAMPLE FILE, safe to commit.
# Copy to server/.env and fill in real values. server/.env is gitignored;
# never commit a real connection string, secret, or login key.

# ---------------------------------------------------------------------------
# Database (PostgreSQL — the repository's Prisma schema targets postgresql)
# Local development example; see docs/DATABASE_SETUP.md for setup steps.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://phantomforce:CHANGE-ME@127.0.0.1:5432/phantomforce_dev

# ---------------------------------------------------------------------------
# Auth provider — one of: demo | prisma-dev | database | owner-production |
# gateway-forwarded
#   demo              in-memory seed sessions (dev only, no DB needed)
#   prisma-dev        seeded Prisma sessions (dev only, session-id login)
#   database          REAL multi-user auth: Postgres users, password login,
#                     org memberships, invitations (dev + production)
#   owner-production  single owner key login (the current admin-PC setup)
#   gateway-forwarded Pangolin forward-auth single sign-on
# ---------------------------------------------------------------------------
PHANTOMFORCE_AUTH_PROVIDER=database

# Required for every provider in production; >= 32 chars, non-default.
PHANTOMFORCE_SESSION_SECRET=CHANGE-ME-to-a-long-random-string-32-chars-min

# Session TTL (ms). Default 8h.
# PHANTOMFORCE_SESSION_TTL_MS=28800000

# Invitation TTL (ms). Default 7 days.
# PHANTOMFORCE_INVITATION_TTL_MS=604800000

# database provider, development only: seed the dev identities on boot
# (dev-org-*/dev-user-* fixtures with .local emails). Set false to disable.
# Never runs when NODE_ENV=production.
# PHANTOMFORCE_SEED_DEV_IDENTITIES=true
# PHANTOMFORCE_DEV_SEED_PASSWORD=phantom-dev-password

# ---------------------------------------------------------------------------
# owner-production provider (existing admin-PC setup) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_OWNER_EMAIL=
# PHANTOMFORCE_OWNER_LOGIN_KEY=

# ---------------------------------------------------------------------------
# gateway-forwarded provider (Pangolin) — unchanged
# ---------------------------------------------------------------------------
# PHANTOMFORCE_GATEWAY_SHARED_SECRET=
# PHANTOMFORCE_GATEWAY_ADMIN_USERS=
# PHANTOMFORCE_GATEWAY_CLIENT_MAP=

# ---------------------------------------------------------------------------
# Billing webhook (provider-neutral; no provider integrated yet)
# ---------------------------------------------------------------------------
# PHANTOM_BILLING_WEBHOOK_SECRET=

# Local asset library (Media Lab "Local Assets" drawer). Point ROOT at the
# folder of downloaded/stock media on this machine; LABEL is the neutral name
# customers see (never the folder name). The index is cached on disk inside
# the root so cold starts serve instantly.
# PHANTOMFORCE_LOCAL_ASSET_ROOT=G:\Your Media Folder
# PHANTOMFORCE_LOCAL_ASSET_LABEL=Local library
