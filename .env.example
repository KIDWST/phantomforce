NODE_ENV=development
PORT=5190
HOST=127.0.0.1
DATABASE_URL=postgresql://phantomforce:phantomforce@127.0.0.1:5432/phantomforce
# Auth provider: demo | prisma-dev (development only) | owner-production (launch)
PHANTOMFORCE_AUTH_PROVIDER=demo
PHANTOMFORCE_ENABLE_DEMO_AUTH=true
PHANTOMFORCE_ADMIN_EMAILS=jordan@phantomforce.local
# Owner-controlled production auth (required when PHANTOMFORCE_AUTH_PROVIDER=owner-production).
# Boot fails closed unless: demo auth is off, session secret is strong/non-default (>=32 chars),
# owner email is set, and owner login key is strong (>=16 chars). Set real values only in .env.
PHANTOMFORCE_OWNER_EMAIL=
PHANTOMFORCE_OWNER_LOGIN_KEY=
PHANTOMFORCE_ACCESS_REPOSITORY=
PHANTOMFORCE_PRISMA_STARTUP_TIMEOUT_MS=8000
PHANTOMFORCE_SERVER_LOGGER=true
FALCON_BASE_URL=http://127.0.0.1:8765
PHANTOMFORCE_SESSION_SECRET=replace-with-a-long-random-secret
PHANTOMFORCE_SESSION_TTL_MS=28800000
PHANTOMFORCE_ALLOW_UNSIGNED_SESSION_HEADER=false
PANGOLIN_READONLY_BASE_URL=
PANGOLIN_READONLY_HEALTH_PATH=/api/v1
PANGOLIN_READONLY_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5190/connections/google/oauth/callback

# Phantom AI / Hermes / model router foundation (server-side only).
# OpenRouter credits/API key must be funded and added manually by Jordan; never commit real keys.
PHANTOM_MODEL_ROUTER_MODE=local
PHANTOM_CODEX_MODEL=gpt-5.5
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5.2
PHANTOM_LIVE_PROVIDERS_ENABLED=false
PHANTOM_OPENROUTER_TRANSPORT_ENABLED=false
PHANTOM_FORCE_OPENROUTER_GLM=false
PHANTOM_OPENROUTER_HTTP_REFERER=http://127.0.0.1
ANTHROPIC_API_KEY=
PHANTOM_DEFAULT_TENANT_BUDGET_USD=
PHANTOM_ALLOW_BYOK=false
PHANTOM_HERMES_LEDGER_PATH=
PHANTOM_LOCAL_MODEL_AVAILABLE=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional local fallback. Admin chat defaults to Codex; Ollama is only used
# when the admin explicitly selects the local fallback lane.
PHANTOM_LOCAL_GLM_MODEL=
PHANTOM_OLLAMA_FALLBACK_MODEL=
