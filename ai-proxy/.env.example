# PhantomForce ai-proxy config. Copy this to `.env` and fill it in.
# `.env` is gitignored — NEVER commit real keys.

# --- Resend (demo signup email) ---
# Create a key at https://resend.com  ->  API Keys.  Paste it here only.
RESEND_API_KEY=

# The "from" address.
# Before you verify phantomforce.online in Resend, you can only send to your OWN
# account email, using Resend's shared test sender:
#   PF_DEMO_FROM=PhantomForce <onboarding@resend.dev>
# After verifying the domain (add the DNS records Resend gives you), switch to:
#   PF_DEMO_FROM=PhantomForce <demo@phantomforce.online>
PF_DEMO_FROM=PhantomForce <onboarding@resend.dev>

# Where the demo file lives. The email links here with ?key=<token> appended.
PF_DEMO_DOWNLOAD_URL=

# --- Paid upgrade (stage 3) ---
# Owner-only key that authorizes POST /upgrade (mint + email a Pro access key
# when a subscription goes active). Send it as the `x-admin-key` header.
# Generate a strong random one; never expose it publicly.
PF_ADMIN_KEY=

# --- Public page brain (Codex) ---
# OpenAI key for the homepage Q&A. The page is read-only by construction: the
# proxy only ever returns text — no tools, no actions. Per-visitor daily cap,
# burst throttle, and a global cap keep abuse and spend bounded.
OPENAI_API_KEY=
PF_PROVIDER=openai
# PF_MODEL=gpt-5.1-codex          # or gpt-5.1-codex-mini to run cheaper
# PF_PER_USER_DAILY=5             # questions per visitor per day
# PF_GLOBAL_DAILY_CAP=1000        # total questions per day, all visitors
# PF_MAX_TOKENS=220               # visible reply budget
# PF_MIN_GAP_MS=2500              # min ms between questions from one visitor

# --- Alternative brains (optional) ---
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
