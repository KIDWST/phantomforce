{
  "_comment": "Copy this to termina.config.json (next to server.js) to define your own terminal types. Each becomes an option in every window's dropdown. Commands run on your machine as you; cwd supports ~ for your home directory.",
  "profiles": [
    {
      "id": "pwsh",
      "label": "PowerShell",
      "command": "pwsh.exe",
      "args": ["-NoLogo"],
      "cwd": "~",
      "note": "A PowerShell shell."
    },
    {
      "id": "codex",
      "label": "Codex CLI",
      "command": "pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-Command", "codex"],
      "cwd": "~",
      "note": "Launches the Codex CLI."
    },
    {
      "id": "my-project",
      "label": "My Project (dev)",
      "command": "pwsh.exe",
      "args": ["-NoLogo", "-NoExit", "-Command", "npm run dev"],
      "cwd": "~/Documents/my-project",
      "note": "Starts the dev server in my project."
    },
    {
      "id": "wsl",
      "label": "WSL / bash",
      "command": "wsl.exe",
      "args": [],
      "cwd": "~",
      "note": "A Linux shell via WSL."
    }
  ]
}
