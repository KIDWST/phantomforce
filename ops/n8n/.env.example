# n8n local automation bay — copy to .env in this folder.
# Binds to localhost only. No real credentials belong in this file or in
# any workflow committed to this repo.

N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LISTEN_ADDRESS=127.0.0.1

# Keep n8n's own editor auth on — set a real owner account inside n8n itself
# on first run. Do not put an owner password here.
N8N_USER_MANAGEMENT_DISABLED=false

# Diagnostics phone-home off by default for a local dev instance.
N8N_DIAGNOSTICS_ENABLED=false
