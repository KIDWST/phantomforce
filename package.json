{
  "name": "phantomforce",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev --workspace @phantomforce/server",
    "test:intent": "node scripts/test-phantom-intent-router.mjs",
    "test:auth-boundaries": "node scripts/test-auth-boundaries.mjs",
    "test:customization-ui": "node scripts/test-customization-ui.mjs",
    "test:settings-connections": "node scripts/test-settings-connections.mjs",
    "test:memory": "node scripts/test-memory-retention.mjs",
    "test:automation-workspace": "node scripts/test-automation-workspace.mjs",
    "test:ai-planner": "node scripts/test-ai-planner.mjs",
    "test:chat-companion": "node scripts/test-chat-companion.mjs",
    "test:instant-chat-fallback": "npm run test:instant-chat-fallback --workspace @phantomforce/server",
    "test:content-planner": "node scripts/test-content-planner.mjs",
    "test:contenthub-rembg-recovery": "node scripts/test-contenthub-rembg-recovery.mjs",
    "test:social-analytics": "node scripts/test-social-analytics.mjs",
    "test:page-worker": "node scripts/test-page-worker.mjs",
    "test:medialab-editor": "node scripts/test-medialab-editor.mjs",
    "test:client-setup-audit": "node scripts/audit-client-setup-data-model.mjs",
    "test:client-setup-console": "node scripts/test-client-setup-console.mjs",
    "test:workspace-profiles": "node scripts/test-workspace-profiles.mjs",
    "test:crm-pipeline": "node scripts/test-crm-pipeline.mjs",
    "test:proposal-pipeline": "node scripts/test-proposal-pipeline.mjs",
    "test:workspace-approvals": "node scripts/test-workspace-approvals.mjs",
    "test:managed-growth-report": "node scripts/test-managed-growth-report.mjs && npm run test:managed-growth-report --workspace @phantomforce/server",
    "test:organization-pulse": "node scripts/test-organization-pulse.mjs",
    "test:flowmap": "node scripts/test-flowmap.mjs",
    "test:ai-proxy-worker-security": "node scripts/test-ai-proxy-worker-security.mjs",
    "test:responsive-viewports": "node scripts/test-responsive-viewports.mjs",
    "test:phantomplay": "node scripts/test-phantomplay.mjs && npm run test:phantomplay --workspace @phantomforce/server",
    "test:competitor-intelligence": "node scripts/test-competitor-intelligence.mjs && npm run test:competitor-intelligence --workspace @phantomforce/server",
    "test:workspace-site-builder": "node scripts/test-workspace-site-builder.mjs",
    "test:sites": "npm run test:workspace-site-builder && npm run test:site-store-render --workspace @phantomforce/server",
    "typecheck": "npm run build --workspace @phantomforce/contracts && npm run typecheck --workspace @phantomforce/server",
    "prisma:generate": "npm run prisma:generate --workspace @phantomforce/server"
  },
  "engines": {
    "node": ">=22"
  }
}
