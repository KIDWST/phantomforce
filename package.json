{
  "name": "phantomforce",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev --workspace @phantomforce/server",
    "test:intent": "node scripts/test-phantom-intent-router.mjs",
    "test:dashboard-chat": "node scripts/test-dashboard-chat-quality.mjs && npm run test:instant-chat --workspace @phantomforce/server && npm run test:instant-chat:tools --workspace @phantomforce/server",
    "test:auth-boundaries": "node scripts/test-auth-boundaries.mjs",
    "test:memory": "node scripts/test-memory-retention.mjs",
    "test:content-planner": "node scripts/test-content-planner.mjs",
    "test:medialab-editor": "node scripts/test-medialab-editor.mjs",
    "test:videocut-editor": "node scripts/test-videocut-editor.mjs",
    "test:page-worker": "node scripts/test-page-worker.mjs",
    "test:topbar-media": "node scripts/test-topbar-media-responsive.mjs",
    "test:phantomplay": "node scripts/test-phantomplay.mjs && npm run test:phantomplay --workspace @phantomforce/server && npm run test:phantomplay:edge --workspace @phantomforce/server && npm run test:phantomplay:edge:storage --workspace @phantomforce/server && npm run test:phantomplay:dev-mode --workspace @phantomforce/server && npm run test --workspace @phantomforce/phantomplay-edge-worker",
    "test:competitor-intelligence": "node scripts/test-competitor-intelligence.mjs && npm run test:competitor-intelligence --workspace @phantomforce/server",
    "test:workspace-site-builder": "node scripts/test-workspace-site-builder.mjs",
    "test:organization-settings": "node scripts/test-organization-settings.mjs",
    "test:organization-record-isolation": "node scripts/test-organization-record-isolation.mjs",
    "test:client-setup-console": "node scripts/test-client-setup-console.mjs",
    "test:customization-ui": "node scripts/test-customization-ui.mjs",
    "test:client-setup-audit": "node scripts/audit-client-setup-data-model.mjs",
    "test:crm-pipeline": "node scripts/test-crm-pipeline.mjs",
    "test:proposal-pipeline": "node scripts/test-proposal-pipeline.mjs",
    "test:workspace-approvals": "node scripts/test-workspace-approvals.mjs",
    "test:managed-growth-report": "node scripts/test-managed-growth-report.mjs && npm run test:managed-growth-report --workspace @phantomforce/server",
    "test:database-auth": "powershell -NoProfile -ExecutionPolicy Bypass -File server/scripts/test-auth-database-live.ps1",
    "test:release-critical": "node scripts/test-release-critical.mjs",
    "test:release-full": "npm run test:release-critical && npm run test:database-auth && npm run test:easy-crm:postgres --workspace @phantomforce/server",
    "test:phantomstore": "node scripts/test-phantomstore-ui.mjs && npm run test:phantomstore --workspace @phantomforce/server",
    "test:customer-plan-switching": "node scripts/test-customer-plan-switching.mjs",
    "test:stripe-billing": "node scripts/test-stripe-billing.mjs && npm run test:stripe-billing --workspace @phantomforce/server",
    "test:change-memory": "node scripts/guard-change-memory.mjs",
    "test:command-surface": "node scripts/test-command-surface.mjs",
    "test:claude-live-ship": "node scripts/test-claude-live-ship.mjs",
    "security:secrets": "node scripts/secret-scan.mjs",
    "security:secrets:strict": "node scripts/secret-scan.mjs --results=verified,unknown",
    "verify:live-admin": "node scripts/ship-live-admin.mjs --verify-only",
    "ship:live-admin": "node scripts/ship-live-admin.mjs",
    "test:sites": "npm run test:workspace-site-builder && npm run test:site-store-render --workspace @phantomforce/server",
    "typecheck": "npm run build --workspace @phantomforce/contracts && npm run typecheck --workspace @phantomforce/server",
    "prisma:generate": "npm run prisma:generate --workspace @phantomforce/server"
  },
  "engines": {
    "node": ">=22"
  }
}
